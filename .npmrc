# Electron-specific configuration
# This helps with Electron installation and caching

# Electron mirror (uncomment if download issues occur)
# electron_mirror=https://npm.taobao.org/mirrors/electron/

# Build from source (set to false for faster installs)
electron_builder_binaries_mirror=https://github.com/electron-userland/electron-builder-binaries/releases/download/

# Increase network timeout for large downloads
network-timeout=600000

# Disable SSL verification if behind corporate proxy (not recommended for production)
# strict-ssl=false

